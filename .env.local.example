# Google Places API — required for live reviews and star rating
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "Places API (New)"
# 3. Create an API key → restrict it to "Places API (New)" only
GOOGLE_PLACES_API_KEY=your_api_key_here

# Papa Dan's Google Place ID
# Find it at: https://developers.google.com/maps/documentation/places/web-service/place-id
# Search for "Papa Dan's Pizza & Pasta Palm Desert CA"
GOOGLE_PLACE_ID=your_place_id_here

# Add both of these as Environment Variables in Vercel:
# Vercel dashboard → Project → Settings → Environment Variables
